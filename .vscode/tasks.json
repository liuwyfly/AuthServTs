{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "copy generated to dist",
            "type": "shell",
            "command": "robocopy src/generated dist/generated /E & if %ERRORLEVEL% LEQ 1 exit 0",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "build",
            "dependsOrder": "sequence",
            "dependsOn": [
                "tsc: build - tsconfig.json",
                "copy generated to dist"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
